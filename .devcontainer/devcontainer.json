{
  "name": "Spring Boot Dev Environment",
  "image": "://microsoft.com",
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vmware.vscode-spring-boot",
        "vscjava.vscode-spring-initializr",
        "vscjava.vscode-spring-boot-dashboard"
      ]
    }
  },
  "forwardPorts": [8080],
  "postCreateCommand": "mvn clean install -DskipTests"
}
